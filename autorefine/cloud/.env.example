# -- AutoRefine Cloud Server Config --

# Upwell's master API keys for upstream providers
UPWELL_OPENAI_KEY=sk-...
UPWELL_ANTHROPIC_KEY=sk-ant-...
UPWELL_MISTRAL_KEY=...

# PostgreSQL connection
DATABASE_URL=postgresql://user:pass@localhost:5432/autorefine_cloud

# Stripe (optional -- disable for internal/client-only deployments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_METERED=price_...

# Server
CLOUD_HOST=0.0.0.0
CLOUD_PORT=8080
CLOUD_WORKERS=4

# Security
CLOUD_CORS_ORIGINS=https://dashboard.autorefine.dev
CLOUD_RATE_LIMIT_DEFAULT=600

# Markup rates by plan (can be overridden per-org in the database)
MARKUP_RATE_INTERNAL=0.0
MARKUP_RATE_CLIENT=0.10
MARKUP_RATE_SELF_SERVE=0.35

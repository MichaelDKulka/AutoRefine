# AutoRefine Configuration
# Copy this file to .env and fill in your values

# Your primary LLM API key (OpenAI, Anthropic, etc.)
AUTOREFINE_API_KEY=

# API key for the refiner model (defaults to Anthropic Claude)
AUTOREFINE_REFINER_KEY=

# Refiner model to use (default: claude-sonnet-4-20250514)
AUTOREFINE_REFINER_MODEL=claude-sonnet-4-20250514

# Storage backend: json, sqlite, postgres (default: json)
AUTOREFINE_STORE_TYPE=json

# Path for file-based storage (default: ~/.autorefine/store.json)
AUTOREFINE_STORE_PATH=

# Postgres connection string (only if AUTOREFINE_STORE_TYPE=postgres)
AUTOREFINE_DATABASE_URL=

# Dashboard port (default: 8787)
AUTOREFINE_DASHBOARD_PORT=8787

# Dashboard password (optional, enables basic auth)
AUTOREFINE_DASHBOARD_PASSWORD=

# Monthly cost limit for refiner calls in USD (default: 50.0)
AUTOREFINE_COST_LIMIT=50.0

# Minimum feedback count before triggering refinement (default: 10)
AUTOREFINE_REFINE_THRESHOLD=10

# A/B test traffic split for candidate prompts, 0.0-1.0 (default: 0.2)
AUTOREFINE_AB_TEST_SPLIT=0.2
